{
  "name": "vrpc",
  "version": "0.0.1",
  "description": "Versioning layer for typed RPC. Pin a client to a version, walk back through each procedure's timeline.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "trpc",
    "rpc",
    "versioning",
    "typescript",
    "api"
  ],
  "author": "Jackson Booth",
  "license": "MIT",
  "peerDependencies": {
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "@trpc/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "zod": "^3.22.0"
  }
}
