{
  "name": "versionrpc",
  "version": "0.0.2",
  "description": "Versioning layer for tRPC. Pin a client to a version, walk inputs forward through each procedure's timeline.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "trpc",
    "rpc",
    "versioning",
    "versioned",
    "migration",
    "schema",
    "schema-evolution",
    "backward-compatibility",
    "api",
    "typescript",
    "zod",
    "procedure",
    "pin"
  ],
  "author": "Jackson Booth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xJaksun/vrpc.git"
  },
  "peerDependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "@trpc/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "zod": "^3.22.0"
  }
}
